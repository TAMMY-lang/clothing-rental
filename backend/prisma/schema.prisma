generator client {
  provider = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x", "debian-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}
model User {
  id         String   @id @default(uuid())
  name       String
  phone      String   @unique
  passwordHash String?
  passwordHistory String @default("[]")
  loginFailCount Int @default(0)
  loginLockUntil DateTime?
  paymentPasswordHash String?
  paymentFailCount Int @default(0)
  paymentLockUntil DateTime?
  lastLoginAt DateTime?
  lastLoginIp String?
  totpSecret String?
  totpEnabled Boolean @default(false)
  activeSessionId String?
  sessionExpiresAt DateTime?
  disabled Boolean @default(false)
  disabledAt DateTime?
  role       String   @default("USER")
  customSize String?
  orders     Order[]
  payments   Payment[]
  cartItems  CartItem[]
  favorites  Favorite[]
  loginLogs  LoginLog[]
  devices    Device[]
  sessions   UserSession[]
  productReviews ProductReview[]
  tenantReviewsReceived MerchantTenantReview[] @relation("TenantReviewsReceived")
  tenantReviewsGiven MerchantTenantReview[] @relation("TenantReviewsGiven")
  customerConversations ChatConversation[] @relation("CustomerConversations")
  merchantConversations ChatConversation[] @relation("MerchantConversations")
  chatMessages ChatMessage[]
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model LoginLog {
  id        String   @id @default(uuid())
  userId    String?
  phone     String
  ip        String?
  device    String?
  success   Boolean  @default(false)
  reason    String?
  role      String?
  createdAt DateTime @default(now())
  user      User?    @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([userId, createdAt])
  @@index([phone, createdAt])
}

model UserSession {
  id           String   @id @default(uuid())
  userId       String
  deviceName   String
  deviceId     String
  ip           String
  userAgent    String?
  loginAt      DateTime @default(now())
  lastActiveAt DateTime @default(now())
  expiresAt    DateTime
  isActive     Boolean  @default(true)
  logoutAt     DateTime?
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, isActive])
  @@index([deviceId])
}

model SecuritySetting {
  id                  String   @id @default(uuid())
  totpRequired        Boolean  @default(true)
  smsFallbackEnabled  Boolean  @default(true)
  singleDeviceLogin   Boolean  @default(true)
  passwordMinLength   Int      @default(8)
  passwordMaxLength   Int      @default(20)
  passwordHistoryLimit Int     @default(3)
  loginFailCaptchaAt  Int      @default(3)
  loginFailLockAt     Int      @default(5)
  paymentFailLockAt   Int      @default(3)
  updatedAt           DateTime @updatedAt
  createdAt           DateTime @default(now())
}

model Device {
  id            String   @id @default(uuid())
  userId        String
  deviceId      String
  deviceName    String?
  ip            String?
  trusted       Boolean  @default(false)
  smsVerified   Boolean  @default(false)
  lastLoginAt   DateTime @default(now())
  createdAt     DateTime @default(now())
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, deviceId])
  @@index([userId])
}

model Product {
  id               String          @id @default(uuid())
  name             String
  category         String
  style            String?
  scenario         String?
  tagPrice         Float
  dailyRentalPrice Float
  depositAmount    Float
  tags             String          @default("[]")
  mainImage        String?
  videoUrl         String?
  explanation      String?
  detailImages     String          @default("[]")
  images           String          @default("[]")
  conditionLevel   String          @default("九成新及以上")
  shippingMethods  String          @default("[\"PICKUP\",\"EXPRESS\"]")
  cleaningStandard String          @default("一单一清洗，入库前消毒熨烫")
  sizeAdvice       String          @default("建议结合身高、体重、胸围、腰围选择，可咨询商家")
  shippingNote     String          @default("租赁周期不含路上运输时间，发货与归还物流时间需提前预留")
  status           String          @default("ACTIVE")
  specs            ProductSpec[]
  orders           Order[]
  bookings         InventoryBooking[]
  cartItems        CartItem[]
  favorites        Favorite[]
  conversations    ChatConversation[]
  reviews          ProductReview[]
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt
}

model ProductCategory {
  id        String   @id @default(uuid())
  name      String   @unique
  sortOrder Int      @default(0)
  enabled   Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model ProductSpec {
  id        String             @id @default(uuid())
  productId String
  skuCode   String?
  color     String?
  size      String?
  bust      Float?
  waist     Float?
  stock     Int                @default(1)
  product   Product            @relation(fields: [productId], references: [id], onDelete: Cascade)
  orders    Order[]
  bookings  InventoryBooking[]
  cartItems CartItem[]
  reviews   ProductReview[]
  createdAt DateTime           @default(now())
  updatedAt DateTime           @updatedAt

  @@index([productId])
}

model InventoryBooking {
  id         String      @id @default(uuid())
  productId  String
  specId     String
  orderId    String
  bookedDate DateTime
  product    Product     @relation(fields: [productId], references: [id], onDelete: Cascade)
  spec       ProductSpec @relation(fields: [specId], references: [id], onDelete: Cascade)
  order      Order       @relation(fields: [orderId], references: [id], onDelete: Cascade)
  createdAt  DateTime    @default(now())

  @@index([specId, bookedDate])
  @@index([productId, bookedDate])
}

model Order {
  id               String             @id @default(uuid())
  userId           String
  productId        String
  specId           String
  rentStartDate    DateTime
  rentEndDate      DateTime
  rentalDays       Int
  rentalFee        Float
  deposit          Float
  totalAmount      Float
  originalTotalAmount Float?
  priceAdjustmentReason String?
  status           String             @default("PENDING_PAYMENT")
  extensionType    String?
  extensionProof   String?
  extensionDays    Int?
  extensionFee     Float?
  shipmentDelayedUntil DateTime?
  shipmentDelayReason String?
  returnRequestedAt DateTime?
  inspectedAt      DateTime?
  cleaningFee      Float?
  depositRefund    Float?
  shippingMethod   String             @default("PICKUP")
  shippingAddress  String?
  pickupLocation   String?
  expressFee       Float              @default(0)
  logisticsCompany String?
  logisticsTrackingNumber String?
  logisticsStatus  String?
  logisticsHistory String             @default("[]")
  shippedAt        DateTime?
  orderType        String             @default("RENTAL")
  tryOnFee         Float              @default(0)
  tryOnQuantity    Int                @default(0)
  tryOnDecision    String?
  returnAddressId  String?
  interceptStatus  String?
  interceptReason  String?
  interceptRefund  Float?
  interceptedAt    DateTime?
  settlementDate   DateTime?
  settlementStatus String?
  user             User               @relation(fields: [userId], references: [id])
  product          Product            @relation(fields: [productId], references: [id])
  spec             ProductSpec        @relation(fields: [specId], references: [id])
  bookings         InventoryBooking[]
  extensionReviews ExtensionReview[]
  payments         Payment[]
  productReview    ProductReview?
  tenantReview     MerchantTenantReview?
  createdAt        DateTime           @default(now())
  updatedAt        DateTime           @updatedAt

  @@index([userId, status])
  @@index([productId, specId])
}

model TryOnSetting {
  id           String   @id @default(uuid())
  enabled      Boolean  @default(true)
  feeRules     String   @default("[]")
  processNote  String   @default("确认租赁：试穿结束后寄回衣服，商家收到并验收后退押金和试穿费用。不租赁：需当天寄回，商家收到后退租金和押金，试穿费用不退。")
  careNotice   String   @default("试穿期间请避免衣服弄脏、破损、香水残留和明显褶皱；如产生清洁或修复费用，将从押金中扣除。")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model ReturnAddress {
  id          String   @id @default(uuid())
  label       String
  receiver    String
  phone       String
  address     String
  isDefault   Boolean  @default(false)
  enabled     Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Payment {
  id              String   @id @default(uuid())
  orderId         String
  userId          String
  amount          Float
  type            String   @default("ORDER_PAY")
  method          String   @default("MOCK")
  status          String   @default("PENDING")
  transactionId   String?
  refundAmount    Float?
  rawPayload      String?
  order           Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([orderId, status])
  @@index([userId, status])
}

model ShopAnnouncement {
  id        String   @id @default(uuid())
  title     String
  content   String
  enabled   Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Coupon {
  id             String   @id @default(uuid())
  title          String
  code           String   @unique
  type           String   @default("AMOUNT")
  discountAmount Float?
  discountPercent Float?
  minOrderAmount Float    @default(0)
  enabled        Boolean  @default(true)
  usageLimit     Int?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

model CartItem {
  id        String      @id @default(uuid())
  userId    String
  productId String
  specId    String
  quantity  Int         @default(1)
  user      User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  product   Product     @relation(fields: [productId], references: [id], onDelete: Cascade)
  spec      ProductSpec @relation(fields: [specId], references: [id], onDelete: Cascade)
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt

  @@unique([userId, productId, specId])
  @@index([userId])
}

model Favorite {
  id        String   @id @default(uuid())
  userId    String
  productId String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([userId, productId])
  @@index([userId])
}

model MerchantWallet {
  id        String   @id @default(uuid())
  balance   Float    @default(0)
  frozen    Float    @default(0)
  totalIncome Float   @default(0)
  transactions WalletTransaction[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Withdrawal {
  id          String   @id @default(uuid())
  amount      Float
  accountName String
  accountNo   String
  channel     String   @default("BANK")
  channelAccount String @default("")
  channelName String   @default("")
  methodId    String?
  status      String   @default("PENDING")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model ShopSetting {
  id                  String   @id @default(uuid())
  settlementDays      Int      @default(7)
  minWithdrawalAmount Float    @default(100)
  withdrawalFeePercent Float   @default(0)
  withdrawalFeeFixed  Float    @default(0)
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
}

model WithdrawalMethod {
  id             String   @id @default(uuid())
  channel        String
  accountName    String
  accountNo      String
  bankName       String?
  qrCode         String?
  isDefault      Boolean  @default(false)
  enabled        Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

model WalletTransaction {
  id            String   @id @default(uuid())
  walletId      String
  type          String
  amount        Float
  balanceBefore Float
  balanceAfter  Float
  orderId       String?
  withdrawalId  String?
  note          String?
  wallet        MerchantWallet @relation(fields: [walletId], references: [id], onDelete: Cascade)
  createdAt     DateTime @default(now())

  @@index([walletId, createdAt])
  @@index([orderId])
  @@index([withdrawalId])
}

model MemberLevel {
  id              String   @id @default(uuid())
  name            String
  minSpend        Float    @default(0)
  discountPercent Float    @default(100)
  benefits        String   @default("[]")
  enabled         Boolean  @default(true)
  sortOrder       Int      @default(0)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model ChatConversation {
  id         String        @id @default(uuid())
  customerId String
  merchantId String
  productId  String?
  status     String        @default("OPEN")
  customer   User          @relation("CustomerConversations", fields: [customerId], references: [id], onDelete: Cascade)
  merchant   User          @relation("MerchantConversations", fields: [merchantId], references: [id], onDelete: Cascade)
  product    Product?      @relation(fields: [productId], references: [id], onDelete: SetNull)
  messages   ChatMessage[]
  createdAt  DateTime      @default(now())
  updatedAt  DateTime      @updatedAt

  @@index([customerId])
  @@index([merchantId])
  @@index([productId])
}

model ChatMessage {
  id             String           @id @default(uuid())
  conversationId String
  senderId       String
  content        String
  conversation   ChatConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  sender         User             @relation(fields: [senderId], references: [id], onDelete: Cascade)
  createdAt      DateTime         @default(now())

  @@index([conversationId, createdAt])
  @@index([senderId])
}

model ProductReview {
  id                String      @id @default(uuid())
  orderId           String      @unique
  userId            String
  productId         String
  specId            String
  overallScore      Int
  cleanlinessScore  Int
  sizeAccuracyScore Int
  matchScore        Int
  content           String
  images            String      @default("[]")
  status            String      @default("PENDING")
  merchantReply     String?
  reviewedAt        DateTime?
  reviewedById      String?
  order             Order       @relation(fields: [orderId], references: [id], onDelete: Cascade)
  user              User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  product           Product     @relation(fields: [productId], references: [id], onDelete: Cascade)
  spec              ProductSpec @relation(fields: [specId], references: [id], onDelete: Cascade)
  createdAt         DateTime    @default(now())
  updatedAt         DateTime    @updatedAt

  @@index([productId, status])
  @@index([userId])
}

model MerchantTenantReview {
  id         String   @id @default(uuid())
  orderId    String   @unique
  merchantId String
  customerId String
  careScore  Int
  comment    String?
  order      Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  merchant   User     @relation("TenantReviewsGiven", fields: [merchantId], references: [id], onDelete: Cascade)
  customer   User     @relation("TenantReviewsReceived", fields: [customerId], references: [id], onDelete: Cascade)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([merchantId])
  @@index([customerId])
}

model ExtensionReview {
  id             String                @id @default(uuid())
  orderId        String
  type           String
  requestedEndDate DateTime
  proof          String?
  fee            Float
  status         String                @default("PENDING")
  rejectReason   String?
  reviewedAt     DateTime?
  order          Order                 @relation(fields: [orderId], references: [id], onDelete: Cascade)
  createdAt      DateTime              @default(now())
  updatedAt      DateTime              @updatedAt

  @@index([orderId, status])
}
