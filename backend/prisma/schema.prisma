generator client {
  provider = "prisma-client-js"
  binaryTargets = ["native", "debian-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id         String   @id @default(uuid())
  name       String
  phone      String   @unique
  passwordHash String?
  passwordHistory String @default("[]")
  loginFailCount Int @default(0)
  loginLockUntil DateTime?
  paymentPasswordHash String?
  paymentFailCount Int @default(0)
  paymentLockUntil DateTime?
  role String @default("USER")
  avatar String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
